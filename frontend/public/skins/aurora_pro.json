    "--contract-quiz-error-border": "color-mix(in oklch, #ef4444 70%, white 30%)",
    "--contract-quiz-shadow-success": "0 0 0 3px color-mix(in oklch, #22c55e 35%, transparent)",
    "--contract-quiz-shadow-error": "0 0 0 3px color-mix(in oklch, #ef4444 35%, transparent)",

