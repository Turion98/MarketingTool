    "--contract-media-border-style": "solid",
    "--contract-media-border-color": "color-mix(in oklch, #82e7ff 40%, transparent)",
    "--contract-media-border-gradient": "linear-gradient(180deg, rgba(130,231,255,.30), rgba(183,139,250,.18))",
