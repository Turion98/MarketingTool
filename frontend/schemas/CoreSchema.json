{
  "$id": "https://qzera.dev/schemas/story/CoreSchema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Qzera Story Core Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "storyId", "meta", "pages"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "title": "Schema version (SemVer)",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "storyId": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "minLength": 2 },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "coverImage": { "type": "string" },
        "logo": {
          "type": "string",
          "description": "Story / brand logo asset path (ugyanaz, amit a header + MediaFrame használ)."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ctaPresets": {
          "description": "Globális CTA presetek, kulcs: presetId (pl. 'default').",
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/CtaPreset" }
        },
        "endDefaultCta": {
          "description": "Alapértelmezett CTA preset az end / finálé oldalhoz.",
          "type": "string",
          "minLength": 1
        },
        "startPageId": { "type": "string" },
        "campaignId": { "type": "string" }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "features": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "transition",
              "voice",
              "sfxPlaylist",
              "layoutHints",
              "globalUI",
              "runes",
              "fragments",
              "puzzle"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "fragments": {
      "description": "Global fragment bank (object map formátum, runtime kompatibilis).",
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/FragmentDef" }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Page" }
    },
    "layout": {},
    "globalUI": {},
    "x-notes": {},
    "x-*": {}
  },
  "patternProperties": {
    "^x-.*$": {}
  },
  "$defs": {
    "Page": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "text": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "minItems": 0,
              "items": {
                "oneOf": [
                  { "type": "string" },
                  { "$ref": "#/$defs/TextBlock" }
                ]
              }
            }
          ]
        },
        "next": { "$ref": "#/$defs/Next" },
        "choices": {
          "type": "array",
          "items": { "$ref": "#/$defs/Choice" }
        },
        "fragments": {
          "type": "array",
          "items": { "$ref": "#/$defs/FragmentRef" },
          "uniqueItems": true
        },
        "runes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "voicePrompt": { "$ref": "#/$defs/VoicePrompt" },
        "sfxPlaylist": {
          "type": "array",
          "items": { "$ref": "#/$defs/SfxEvent" }
        },
        "imagePrompt": { "$ref": "#/$defs/ImagePrompt" },
        "imageTiming": { "$ref": "#/$defs/ImageTiming" },
        "reward": { "$ref": "#/$defs/Reward" },
        "type": {
          "type": "string",
          "enum": ["default", "transition", "puzzle", "decision", "fragmentRecall", "end", "logic", "scorecard", "conditionalRouting"],
          "default": "default"
        },
        "title": { "type": "string" },
        "scorecardFallback": {
          "description": "Ha egyik scorecard/logic tömbös szabály sem illeszkedik, ide ugrik (opcionális).",
          "type": "string",
          "minLength": 1
        },
        "logic": {
          "description": "Logic routing: array of if/goto rules (coffee style) or ifHasFragment/elseGoTo object (Mrk6 style).",
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/LogicRule" }
            },
            { "$ref": "#/$defs/LogicObject" }
          ]
        },
        "layout": {},
        "globalUI": {},
        "x-notes": {},
        "x-*": {}
      },
      "patternProperties": {
        "^x-.*$": {}
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "transition" } } },
          "then": { "$ref": "#/$defs/TransitionPage" }
        },
        {
          "if": { "properties": { "type": { "const": "puzzle" } } },
          "then": { "$ref": "#/$defs/PuzzlePage" }
        },
        {
          "if": { "properties": { "type": { "const": "fragmentRecall" } } },
          "then": { "$ref": "#/$defs/FragmentRecallPage" }
        }
      ]
    },
    "Next": {
      "description": "Either a direct pageId (string) or a switch-based router object.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/NextSwitch" }
      ]
    },
    "NextSwitch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["switch", "cases"],
      "properties": {
        "switch": { "type": "string", "minLength": 1 },
        "cases": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "default": { "type": "string", "minLength": 1 }
      }
    },
    "Choice": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "nextPageId": { "type": "string", "minLength": 1 },
        "next": { "type": "string", "minLength": 1 },
        "lockedIf": { "type": "string" },
        "hideIfHasFragment": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "showIfHasFragment": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "reward": { "$ref": "#/$defs/Reward" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Action" }
        },
        "analytics": { "type": "object" },
        "extras": { "type": "object" },
        "x-*": {}
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["text"] }
      ],
      "patternProperties": {
        "^x-.*$": {}
      }
    },
    "Action": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type": { "const": "setFlag" },
            "flag": { "type": "string" },
            "id": { "type": "string" },
            "value": {}
          },
          "anyOf": [
            { "required": ["type", "flag"] },
            { "required": ["type", "id"] }
          ]
        },
        {
          "properties": {
            "type": { "const": "unlockFragment" },
            "fragmentId": { "type": "string" }
          },
          "required": ["type", "fragmentId"]
        },
        {
          "properties": {
            "type": { "const": "lock" },
            "key": { "type": "string" }
          },
          "required": ["type", "key"]
        },
        {
          "properties": {
            "type": { "const": "unlock" },
            "key": { "type": "string" }
          },
          "required": ["type", "key"]
        }
      ]
    },
    "Reward": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "setGlobal": {
          "type": "object",
          "additionalProperties": true
        },
        "locks": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "unlocks": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "unlockFragments": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "FragmentDef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "text": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "replayImage": { "type": "string" },
        "extras": { "type": "object" },
        "x-*": {}
      },
      "patternProperties": {
        "^x-.*$": {}
      }
    },
    "FragmentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "extras": { "type": "object" }
      }
    },
    "TextBlock": {
      "description": "Feltételes vagy kiegészítő szövegblokk (ifUnlocked/default stb.).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "default": { "type": "string" },
        "ifUnlocked": { "type": "string" },
        "mode": { "type": "string" },
        "separator": { "type": "string" }
      },
      "anyOf": [
        { "required": ["text"] },
        { "required": ["default"] }
      ]
    },
    "VoicePrompt": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": { "type": "string" },
            "voice": { "type": "string" },
            "lang": { "type": "string" }
          }
        }
      ]
    },
    "SfxEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["atMs", "src"],
      "properties": {
        "atMs": { "type": "integer", "minimum": 0 },
        "src": { "type": "string", "minLength": 1 },
        "gainDb": { "type": "number" },
        "duck": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "duckToDb": { "type": "number" },
            "attackMs": { "type": "integer", "minimum": 0 },
            "releaseMs": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "ImagePrompt": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["prompt"],
          "properties": {
            "prompt": { "type": "string" },
            "negative": { "type": "string" },
            "styleProfile": { "type": "string" },
            "seed": { "type": "integer" }
          }
        }
      ]
    },
    "ImageTiming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generate": { "type": "boolean" },
        "on": { "type": "string", "enum": ["pageEnter", "afterVoice"] }
      }
    },
    "TransitionPage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "transition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["video", "fog", "cut"] },
            "src": { "type": "string" },
            "durationMs": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "PuzzlePage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "enum": ["runes", "riddle"] },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "answer": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        },
        "maxAttempts": { "type": "integer", "minimum": 1 }
      }
    },
    "FragmentRecallPage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "fragmentRecall": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id"],
          "properties": {
            "id": { "type": "string" },
            "showImage": { "type": "boolean" }
          }
        }
      }
    },
    "LogicRule": {
      "description": "Egy feltételes ugrás: ha minden megadott lock/fragment igaz, menj a goto oldalra.",
      "type": "object",
      "additionalProperties": false,
      "required": ["if", "goto"],
      "properties": {
        "if": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "goto": { "type": "string", "minLength": 1 }
      }
    },
    "LogicIfHasFragment": {
      "description": "Fragment alapú elágazás egy eleme: ha a fragment megvan, menj a goTo oldalra.",
      "type": "object",
      "additionalProperties": false,
      "required": ["fragment", "goTo"],
      "properties": {
        "fragment": { "type": "string", "minLength": 1 },
        "goTo": { "type": "string", "minLength": 1 }
      }
    },
    "LogicObject": {
      "description": "Objektum formátumú logic: ifHasFragment listával és opcionális elseGoTo.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ifHasFragment": {
          "type": "array",
          "items": { "$ref": "#/$defs/LogicIfHasFragment" }
        },
        "elseGoTo": { "type": "string", "minLength": 1 }
      }
    },
    "CtaPreset": {
      "description": "CTA preset definíció (pl. link gomb).",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label"],
      "properties": {
        "kind": { "type": "string", "enum": ["link"] },
        "label": { "type": "string", "minLength": 1 },
        "urlTemplate": {
          "description": "Cél URL vagy templét (pl. query paramokkal).",
          "type": "string",
          "minLength": 1
        },
        "x-*": {}
      },
      "patternProperties": { "^x-.*$": {} }
    }
  }
}
