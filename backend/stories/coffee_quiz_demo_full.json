  "pages": [
    {
      "id": "Q1",
      "title": "",
      "text": [
        {
          "text": "Válaszd ki azt a helyzetet, ami a leginkább ismerős neked a mindennapokból."
        }
      ],
      "choices": [
        {
          "text": "Ha valami kiesik a kezedből, felnevetsz rajta.",
          "next": "Q2",
          "value": "A",
          "reward": {
            "locks": [
              "Q1_A"
            ],
            "unlockFragments": [
              "FRAG_PAGE_SITUATION_1"
            ]
          }
        },
        {
          "text": "Automatikusan elkezded elpakolni a körülötted lévő dolgokat.",
          "next": "Q2",
          "value": "B",
          "reward": {
            "locks": [
              "Q1_B"
            ],
            "unlockFragments": [
              "FRAG_PAGE_SITUATION_2"
            ]
          }
        },
        {
          "text": "Körbenézel, és rögtön észreveszel valami érdekeset.",
          "next": "Q2",
          "value": "C",
          "reward": {
            "locks": [
              "Q1_C"
            ],
            "unlockFragments": [
              "FRAG_PAGE_SITUATION_3"
            ]
          }
        },
        {
          "text": "Inkább csak megállsz egy pillanatra, és veszel egy mély levegőt.",
          "next": "Q2",
          "value": "D",
          "reward": {
            "locks": [
              "Q1_D"
            ],
            "unlockFragments": [
              "FRAG_PAGE_SITUATION_4"
            ]
          }
        }
      ]
    },
    {
      "id": "Q2",
      "title": "",
      "text": [
        {
          "text": "Képzeld el, hogy hirtelen kapsz 10 percet magadra. Mire menne el ez az idő a legszívesebben?"
        }
      ],
      "choices": [
        {
          "text": "Gyorsan elintéznék valami apróságot.",
          "next": "Q3",
          "value": "A",
          "reward": {
            "locks": [
              "Q2_A"
            ],
            "unlockFragments": [
              "FRAG_Q2_VARIANT_1"
            ]
          }
        },
        {
          "text": "Kicsit rendbe tenném a környezetem.",
          "next": "Q3",
          "value": "B",
          "reward": {
            "locks": [
              "Q2_B"
            ],
            "unlockFragments": [
              "FRAG_Q2_VARIANT_2"
            ]
          }
        },
        {
          "text": "Megnéznék valami új dolgot / videót / ötletet.",
          "next": "Q3",
          "value": "C",
          "reward": {
            "locks": [
              "Q2_C"
            ],
            "unlockFragments": [
              "FRAG_Q2_VARIANT_3"
            ]
          }
        },
        {
          "text": "Leülnék csendben, és pihennék.",
          "next": "Q3",
          "value": "D",
          "reward": {
            "locks": [
              "Q2_D"
            ],
            "unlockFragments": [
              "FRAG_Q2_VARIANT_4"
            ]
          }
        }
      ]
    },
    {
      "id": "Q3",
      "title": "",
      "text": [
        {
          "text": "Válaszd ki azt a mondatot, amelyik mostanában a leginkább igaz rád."
        }
      ],
      "choices": [
        {
          "text": "„Jó, ha a dolgok haladnak.”",
          "next": "logic",
          "value": "1",
          "reward": {
            "locks": [
              "Q3_1"
            ]
          }
        },
        {
          "text": "„Jó, ha a dolgok kisimulnak.”",
          "next": "logic",
          "value": "2",
          "reward": {
            "locks": [
              "Q3_2"
            ]
          }
        },
        {
          "text": "„Jó, ha van egy kis játékosság.”",
          "next": "logic",
          "value": "3",
          "reward": {
            "locks": [
              "Q3_3"
            ]
          }
        },
        {
          "text": "„Jó, ha van tér lélegezni.”",
          "next": "logic",
          "value": "4",
          "reward": {
            "locks": [
              "Q3_4"
            ]
          }
        }
      ]
    },
