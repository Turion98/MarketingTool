  "fragments": {
    "FRAG_Q2_VARIANT_1": {
      "id": "FRAG_Q2_VARIANT_1",
      "text": "Szereted, ha a dolgok végül a helyükre kerülnek, és letisztultan állnak előtted."
    },
    "FRAG_Q2_VARIANT_2": {
      "id": "FRAG_Q2_VARIANT_2",
      "text": "Fontos számodra, hogy a környezetedben legyen valamiféle természetes rend és áramlás."
    },
    "FRAG_Q2_VARIANT_3": {
      "id": "FRAG_Q2_VARIANT_3",
      "text": "Könnyen találsz magadnak apró új impulzusokat, amelyek frissen tartják a figyelmed."
    },
    "FRAG_Q2_VARIANT_4": {
      "id": "FRAG_Q2_VARIANT_4",
      "text": "Jól esik, ha marad egy kis belső csend és tér, ahol csak jelen lehetsz."
    },
    "FRAG_PAGE_SITUATION_1": {
      "id": "FRAG_PAGE_SITUATION_1",
      "text": "the coffee appears during a transition moment, between two activities or mental states, when something has just ended and the next thing has not fully begun yet; the environment feels paused, as if allowing a brief reset before moving on"
    },
    "FRAG_PAGE_SITUATION_2": {
      "id": "FRAG_PAGE_SITUATION_2",
      "text": "the coffee is present within an active ongoing situation, not as a break but as a companion; the environment suggests that something is already happening, and the coffee naturally integrates into that flow without stopping it"
    },
    "FRAG_PAGE_SITUATION_3": {
      "id": "FRAG_PAGE_SITUATION_3",
      "text": "the coffee appears in a brief pause that does not fully interrupt momentum; the situation feels momentarily softened, as if space has opened for reflection without losing direction"
    },
    "FRAG_PAGE_SITUATION_4": {
      "id": "FRAG_PAGE_SITUATION_4",
      "text": "the coffee exists in an independent moment with no immediate task attached; the situation feels self-contained, as if the moment is valuable on its own, without needing justification or outcome"
    }
  }
}
