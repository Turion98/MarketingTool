  "fragments": {
    "END_compliance_simple_override": {
      "id": "END_compliance_simple_override",
      "text": "Nálad nem az a fő kérdés, hogy milyen a bőröd, hanem hogy a fényvédő mennyire egyszerűen illeszkedik a napodba. Minél kevesebb ellenállást okoz, annál nagyobb eséllyel lesz belőle napi rutin. Ezért jó választás ez a formula: könnyű, gyors, nem ragad, és nem csinál külön ügyet a használatból."
    },
    "END_active_invisible_override": {
      "id": "END_active_invisible_override",
      "text": "Nálad nem az a kérdés, hogy mennyire hidratál vagy milyen a finish, hanem hogy bírja-e a napodat. Egy rossz fényvédő ilyenkor lefolyik, eltűnik, zavaróvá válik — és egyszerűen elhagyod. Ez a típus pont ezért működik: könnyű, nem csípi a szemet, és mozgás közben sem érzed. Nem kell rá figyelni — és pont ezért marad fent."
    },
    "END_active_context_override": {
      "id": "END_active_context_override",
      "text": "Nálad nem az a fő gond, hogy önmagában rossz lenne a fényvédő, hanem hogy bizonyos helyzetekben nem tudja tartani a tempót. Melegben, mozgás közben vagy izzadásnál sok formula zavaróvá válik, elmozdul vagy egyszerűen kényelmetlen lesz. Ez a típus azért jó választás, mert könnyű marad, nem csípi a szemet, és aktívabb helyzetekben is sokkal élhetőbb viselést ad."
    },
    "END_oily_context_override": {
      "id": "END_oily_context_override",
      "text": "Nálad nem az a fő probléma, hogy önmagában nem működik a fényvédő, hanem hogy napközben elveszíti a stabilitását. Kifényesedik, elcsúszik vagy egyszerűen nem marad egyben a bőrön. Ez a típus segít ezt kontroll alatt tartani: könnyű marad, nem ül rá vastagon a bőrre, és sokkal rendezettebb viselést ad a nap folyamán."
    },
    "END_sensitive_context_override": {
      "id": "END_sensitive_context_override",
      "text": "Nálad nem az a kérdés, hogy működik-e a fényvédelem, hanem hogy a bőröd egyáltalán tolerálja-e. Ha csíp, irritál vagy túl soknak érzed, akkor nem fogod használni — teljesen mindegy mennyire jó a formula. Ezért itt a legfontosabb a minimalizmus és a kíméletesség."
    },
    "END_dry_context_override": {
      "id": "END_dry_context_override",
      "text": "Nálad nem az a gond, hogy nem működik, hanem hogy közben kényelmetlen. Húz, szárít vagy egyszerűen rossz érzet egész nap. Ilyenkor a fényvédelem csak akkor fog működni, ha közben komfortos marad a bőrödön."
    },
    "APPEND_compliance_l1_invisible": {
      "id": "APPEND_compliance_l1_invisible",
      "text": "Úgy látszik, számodra az a jó, ami külön erőfeszítés nélkül beleolvad a napodba."
    },
    "APPEND_compliance_l1_stable": {
      "id": "APPEND_compliance_l1_stable",
      "text": "A válaszaid alapján az is sokat számít, hogy használat közben végig problémamentes maradjon."
    },
    "APPEND_compliance_l1_reacts": {
      "id": "APPEND_compliance_l1_reacts",
      "text": "Számodra az sem mellékes, hogy a bőröd könnyen együtt tudjon élni vele a mindennapokban."
    },
    "APPEND_oily_l1_invisible": {
      "id": "APPEND_oily_l1_invisible",
      "text": "Úgy látszik, számodra itt az is fontos, hogy könnyű maradjon, ne üljön rá feleslegesen a bőrödre."
    },
    "APPEND_oily_l1_stable": {
      "id": "APPEND_oily_l1_stable",
      "text": "A válaszaid alapján főleg az számít, hogy napközben is összeszedett maradjon az érzet."
    },
    "APPEND_oily_l1_reacts": {
      "id": "APPEND_oily_l1_reacts",
      "text": "Számodra az is lényegesnek tűnik, hogy ne borítsa fel a bőröd egyensúlyát viselés közben."
    },
    "APPEND_dry_l1_invisible": {
      "id": "APPEND_dry_l1_invisible",
      "text": "Úgy látszik, számodra az működik jobban, ami kényelmesen jelen van, nem nehezedik rád."
    },
    "APPEND_dry_l1_stable": {
      "id": "APPEND_dry_l1_stable",
      "text": "A válaszaid alapján az is fontos, hogy az érzet napközben se billenjen át húzódásba vagy feszülésbe."
    },
    "APPEND_dry_l1_reacts": {
      "id": "APPEND_dry_l1_reacts",
      "text": "Számodra láthatóan az a jó irány, amihez a bőröd végig nyugodtan tud alkalmazkodni."
    },
    "APPEND_sensitive_l1_invisible": {
      "id": "APPEND_sensitive_l1_invisible",
      "text": "Úgy látszik, számodra itt az is fontos, hogy viselés közben minél kevésbé legyen tolakodó az élmény."
    },
    "APPEND_sensitive_l1_stable": {
      "id": "APPEND_sensitive_l1_stable",
      "text": "A válaszaid alapján számodra sokat jelent, ha kiszámíthatóan, nyugodtan lehet együtt élni vele napközben."
    },
    "APPEND_sensitive_l1_reacts": {
      "id": "APPEND_sensitive_l1_reacts",
      "text": "Számodra egyértelműen az a megnyugtató, amihez a bőrödnek nem kell külön alkalmazkodnia."
    },
    "APPEND_active_l1_invisible": {
      "id": "APPEND_active_l1_invisible",
      "text": "Úgy látszik, számodra itt az a nyerő, amit mozgás közben sem kell külön észben tartani."
    },
    "APPEND_active_l1_stable": {
      "id": "APPEND_active_l1_stable",
      "text": "A válaszaid alapján főleg az számít, hogy terhelés alatt is egyben maradjon az élmény."
    },
    "APPEND_active_l1_reacts": {
      "id": "APPEND_active_l1_reacts",
      "text": "Számodra az is fontosnak tűnik, hogy aktív helyzetben se váljon kellemetlenné a bőrödön."
    }
  }
}