  "pages": [
    {
      "id": "q1_skin_profile",
      "type": "puzzle",
      "kind": "runes",
      "mode": "set",
      "feedback": "reset",
      "title": "Mi jellemző rád inkább?",
      "text": [
        {
          "text": "Válassz 2-t."
        }
      ],
      "options": [
        "Mosakodás után feszül",
        "Fakó / nem ragyog",
        "Napközben kifényesedik",
        "Gyorsan zsírosodik",
        "Látszanak a pórusok",
        "Nem sima a felszín",
        "Könnyen kipirosodik",
        "Csíp / éget"
      ],
      "maxPick": 2,
      "maxAttempts": 1,
      "optionFlagsBase": "skin_opt_",
      "onSuccess": {
        "goto": "q1_router"
      }
    },
    {
      "id": "q1_router",
      "type": "logic",
      "title": "",
      "text": [
        {
          "text": ""
        }
      ],
      "logic": [
        { "if": ["skin_opt_1", "skin_opt_2"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_1", "skin_opt_3"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_1", "skin_opt_4"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_1", "skin_opt_5"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_1", "skin_opt_6"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_1", "skin_opt_7"], "goto": "q2_sensitive_trigger" },
        { "if": ["skin_opt_1", "skin_opt_8"], "goto": "q2_sensitive_trigger" },
        { "if": ["skin_opt_2", "skin_opt_3"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_2", "skin_opt_4"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_2", "skin_opt_5"], "goto": "q2_dry_timing" },
        { "if": ["skin_opt_2", "skin_opt_6"], "goto": "q2_dry_timing" },
