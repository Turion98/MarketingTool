# ============================================
# Backend környezeti változók – példa
# Másold át .env névre és töltsd ki (a .env nincs gitben).
# ============================================

# ---- Képgenerálás (Replicate) ----
# Kötelező, ha a backendnek magának kell generálnia (nincs kulcs a frontendről).
# Lokálban és production backenden is ezt használja a szerver, ha a kérésben nincs apiKey.
REPLICATE_API_TOKEN=r8_USpuULbC0rHkWfgROHolTI7UXClPGme0L8tuh
# Opcionális: másik modell verzió (alapértelmezett hash a kódban van)
# REPLICATE_IMAGE_VERSION=

# ---- Opcionális backend beállítások ----
# STORIES_DIR=./stories
# DEFAULT_STORY=global.json
# ENABLE_IMAGE_CACHE=true
# ENABLE_IMAGE_PRELOAD=true

# ---- Admin / egyéb (ha kell) ----
# ADMIN_KEY=
# FEEDBACK_DIR=
# SECRET_KEY=

# ---- Signed embed access (JWT + grants JSON) ----
# Kötelező token kiadásához / ellenőrzéséhez. A Next REQUIRE_SIGNED_EMBED=true mellett a middleware hívja a verify API-t.
# EMBED_ACCESS_SIGNING_SECRET=change-me-use-long-random-string
# EMBED_ACCESS_GRANTS_PATH=./data/embed_access_grants.json
# Dashboard generate auto-grant flow:
# - ha story_id-hoz nincs aktív grant, automatikusan létrehozza
# - ha van aktív grant, azt használja
# - default token TTL: 365 nap (grant revoke továbbra is azonnal tilt)
