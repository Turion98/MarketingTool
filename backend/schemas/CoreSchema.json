{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://questell.dev/schema/CoreSchema.v2.json",
  "title": "Questell Core Story Schema (v2)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "storyId", "chapters"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer for schema compatibility. Must match renderer major."
    },
    "storyId": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-\\.]{3,64}$"
    },
    "title": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "locale": { "type": "string" },

        "id":        { "type": "string", "pattern": "^[a-z0-9_\\-\\.]{3,64}$" },
        "title":     { "type": "string" },
        "description": { "type": "string" },
        "coverImage": { "type": "string" },

        "startPageId": { "type": "string", "pattern": "^[a-z0-9_\\-\\.]{2,64}$" },
        "campaignId":  { "type": "string", "pattern": "^[a-z0-9_\\-\\.]{2,64}$" },

        "ctaPresets": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/Cta" }
        },

        "endDefaultCta": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "$ref": "#/definitions/Cta" }
          ]
        }
      }
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Chapter" }
    }
  },
  "definitions": {
    "Cta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label"],
      "properties": {
        "kind": { "type": "string", "enum": ["link", "restart"] },
        "label": { "type": "string", "minLength": 1 },
        "urlTemplate": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "link" } }, "required": ["kind"] },
          "then": { "required": ["urlTemplate"] }
        }
      ]
    },

    "Chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pages"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-\\.]{2,64}$"
        },
        "title": { "type": "string" },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Page" }
        }
      }
    },

    "Choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "next"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-\\.]{2,64}$"
        },
        "text": { "type": "string", "minLength": 1 },
        "next": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-\\.]{2,64}$",
          "description": "Target page.id within the same story"
        }
      }
    },

    "PageBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-\\.]{2,64}$"
        },
        "type": {
          "type": "string",
          "enum": ["narrative", "action", "end"]
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "src": { "type": "string" },
            "fit": {
              "type": "string",
              "enum": ["cover", "contain", "fill", "scale-down", "none"]
            },
            "alt": { "type": "string" }
          }
        },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "src": { "type": "string" },
            "loop": { "type": "boolean" }
          }
        },
        "text": { "type": "string" }
      }
    },

    "Page": {
      "allOf": [
        { "$ref": "#/definitions/PageBase" },
        {
          "oneOf": [
            {
              "properties": {
                "type": { "const": "narrative" },
                "choices": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "$ref": "#/definitions/Choice" }
                }
              },
              "required": ["choices"]
            },
            {
              "properties": {
                "type": { "enum": ["narrative", "action"] },
                "next": {
                  "type": "string",
                  "pattern": "^[a-z0-9_\\-\\.]{2,64}$"
                }
              },
              "required": ["next"]
            },
            {
              "properties": { "type": { "const": "end" } }
            }
          ]
        }
      ]
    }
  }
}
