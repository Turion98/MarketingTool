NEXT_PUBLIC_SENTRY_DSN=
# `mock` = egy kattintásos dev belépés (memória). Éles / valós login demó: `session` + lentebbi tier változók.
NEXT_PUBLIC_AUTH_PROVIDER=mock

# ---- Login + fiók szint (NEXT_PUBLIC_AUTH_PROVIDER=session) ----
# A NEXT_PUBLIC_* változók a Next buildnél beégnek a kliensbe — Vercel / CI: állítsd a build előtt, majd újra deploy.
# NEXT_PUBLIC_AUTH_PROVIDER=session
# Opcionális közös jelszó minden teszt usernek (üres = nincs ellenőrzés)
# NEXT_PUBLIC_DEV_LOGIN_PASSWORD=
# Admin szint (vesszővel több cím); a kód kisbetűsít és trimel
# NEXT_PUBLIC_DEV_ADMIN_EMAILS=you@example.com
# Fizetős szint teszt mailek (nincs listán → ingyenes)
# NEXT_PUBLIC_DEV_PAID_EMAILS=

# ---- Iframe beágyazás (/embed/*) — CSP frame-ancestors (middleware) ----
# * = bármely oldal beágyazhatja az embed útvonalakat (alapértelmezés, ha nincs beállítva).
# Szigorúbb: szóközzel vagy vesszővel felsorolt originök, pl. https://client.com https://www.client.com
# Build / dev: EMBED_FRAME_ANCESTORS vagy (Edge middleware-hez) NEXT_PUBLIC_EMBED_FRAME_ANCESTORS
# EMBED_FRAME_ANCESTORS=*

# ---- Login demó iframe: teljes embed URL alap (path: /embed/...) ----
# Ha üres, a böngésző aktuális originjét használjuk (lokális dev).
# Élesben állítsd a publikus oldal originjére, pl. https://www.thequestell.com
# NEXT_PUBLIC_EMBED_PLAYER_ORIGIN=https://www.thequestell.com
# Beágyazás (URL, iframe, embed.js): frontend/docs/embed.md — kód: frontend/app/lib/embedSiteConfig.ts

# ---- Frontend → backend cím ----
# Lokál: alapból a frontend http://127.0.0.1:8000 -ra hív (nem kell beállítani).
# Vercel / production: állítsd be a tényleges backend URL-t (ahol a FastAPI fut).
# NEXT_PUBLIC_API_BASE=https://api.yourapp.com
